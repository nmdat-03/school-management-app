generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       String @id
  username String @unique
}

model AcademicYear {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  startDate DateTime
  endDate   DateTime

  isActive Boolean @default(false)

  semesters   Semester[]
  enrollments Enrollment[]

  @@index([startDate])
  @@index([endDate])
}

model Semester {
  id   Int    @id @default(autoincrement())
  name String

  startDate DateTime
  endDate   DateTime

  academicYearId Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  exams          Exam[]
  assignments    Assignment[]

  @@unique([academicYearId, name])
}

model Student {
  id        String     @id
  username  String     @unique
  name      String
  surname   String
  email     String?    @unique
  phone     String?    @unique
  address   String
  img       String?
  gender    UserGender
  birthday  DateTime
  createdAt DateTime   @default(now())

  parentId String
  parent   Parent @relation(fields: [parentId], references: [id])

  enrollments       Enrollment[]
  attendances       Attendance[]
  examResults       ExamResult[]
  assignmentResults AssignmentResult[]

  @@index([name])
  @@index([surname])
}

model Teacher {
  id        String     @id
  username  String     @unique
  name      String
  surname   String
  email     String?    @unique
  phone     String?    @unique
  address   String
  img       String?
  gender    UserGender
  birthday  DateTime
  createdAt DateTime   @default(now())

  subjects  Subject[]
  schedules Schedule[]
  classes   Class[]

  exams       Exam[]
  assignments Assignment[]

  @@index([name])
  @@index([surname])
}

model Parent {
  id        String   @id
  username  String   @unique
  name      String
  surname   String
  email     String?  @unique
  phone     String   @unique
  address   String
  createdAt DateTime @default(now())

  students Student[]
}

model Grade {
  id    Int @id @default(autoincrement())
  level Int @unique

  classes Class[]
}

model Class {
  id       Int    @id @default(autoincrement())
  name     String @unique
  capacity Int

  gradeId Int
  grade   Grade @relation(fields: [gradeId], references: [id])

  supervisorId String?
  supervisor   Teacher? @relation(fields: [supervisorId], references: [id])

  enrollments Enrollment[]

  schedules   Schedule[]
  exams       Exam[]
  assignments Assignment[]
  attendances Attendance[]

  events        Event[]
  announcements Announcement[]

  @@index([gradeId])
}

model Enrollment {
  id Int @id @default(autoincrement())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  academicYearId Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentId, classId, academicYearId])
  @@index([classId])
  @@index([academicYearId])
  @@index([studentId])
}

model Subject {
  id   Int    @id @default(autoincrement())
  name String @unique

  teachers    Teacher[]
  schedules   Schedule[]
  exams       Exam[]
  assignments Assignment[]

  @@index([name])
}

model Schedule {
  id        Int    @id @default(autoincrement())
  day       Day
  startTime String
  endTime   String

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  @@unique([classId, day, startTime])
  @@unique([teacherId, day, startTime])
  @@index([classId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([day])
}

model Exam {
  id        Int      @id @default(autoincrement())
  title     String
  startTime DateTime
  endTime   DateTime
  maxScore  Int      @default(10)
  createdAt DateTime @default(now())

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  semesterId Int
  semester   Semester @relation(fields: [semesterId], references: [id])

  results ExamResult[]

  @@index([classId])
  @@index([teacherId])
  @@index([semesterId])
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  startDate DateTime
  dueDate   DateTime
  maxScore  Int      @default(10)
  createdAt DateTime @default(now())

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  semesterId Int
  semester   Semester @relation(fields: [semesterId], references: [id])

  results AssignmentResult[]

  @@index([classId])
  @@index([teacherId])
  @@index([semesterId])
}

model ExamResult {
  id Int @id @default(autoincrement())

  score Int

  examId Int
  exam   Exam @relation(fields: [examId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@index([studentId])
  @@index([examId])
}

model AssignmentResult {
  id Int @id @default(autoincrement())

  score Int

  assignmentId Int
  assignment   Assignment @relation(fields: [assignmentId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId])
}

model Attendance {
  id      Int      @id @default(autoincrement())
  date    DateTime
  present Boolean

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
  @@index([studentId])
  @@index([classId])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])

  @@index([classId])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])

  @@index([classId])
}

enum UserGender {
  MALE
  FEMALE
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}
